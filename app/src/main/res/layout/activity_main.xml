<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla principal de RestauranteApp -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_fondo_restaurante"
    android:fillViewport="true">

    <!-- Contenedor general de la pantalla -->
    <LinearLayout
        android:id="@+id/layoutPrincipal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- Tarjeta principal blanca -->
        <LinearLayout
            android:id="@+id/cardInicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_tarjeta_blanca"
            android:elevation="8dp"
            android:padding="26dp">

            <!-- Icono superior de restaurante -->
            <ImageView
                android:id="@+id/imgRestaurante"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/ic_restaurante"
                android:background="@drawable/bg_circulo_turquesa"
                android:padding="18dp"
                android:contentDescription="Icono de restaurante" />

            <!-- Título principal -->
            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Restaurante"
                android:textColor="@color/gris_oscuro"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp" />

            <!-- Texto descriptivo -->
            <TextView
                android:id="@+id/txtDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sistema simple para registrar exámenes y pedidos."
                android:textColor="@color/gris_medio"
                android:textSize="15sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp" />

            <!-- Botón para ir a Registro de Exámenes -->
            <Button
                android:id="@+id/btnExamenes"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Exámenes"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/blanco"
                android:background="@drawable/bg_boton_verde_oscuro"
                android:layout_marginBottom="14dp" />

            <!-- Botón para ir a Pedido -->
            <Button
                android:id="@+id/btnPedido"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Pedido"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/gris_oscuro"
                android:background="@drawable/bg_boton_rosado"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- Texto inferior decorativo -->
        <TextView
            android:id="@+id/txtPie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Proyecto académico"
            android:textColor="@color/blanco_suave"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="22dp" />

    </LinearLayout>

</ScrollView>